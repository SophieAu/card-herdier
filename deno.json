{
  "tasks": {
    "dev": "deno run --env --unstable-cron src/main.ts",
    "lint": "deno lint",
    "format": "deno fmt",
    "typecheck": "deno check src/**/*.ts",
    "db-gen": "deno --env -A --node-modules-dir npm:drizzle-kit pull"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@tcgdex/sdk": "npm:@tcgdex/sdk@^2.7.1",
    "@types/pg": "npm:@types/pg@^8.18.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.9",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "pg": "npm:pg@^8.20.0",
    "resend": "npm:resend@^6.9.3"
  }
}
